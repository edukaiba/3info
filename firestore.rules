rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // HELPERS
    // ---------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ---------------------------------------------------------
    // VALIDATION HELPERS
    // ---------------------------------------------------------

    function isValidContact(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'message', 'createdAt'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.subject is string && data.subject.size() > 0 && data.subject.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'photoURL', 'role'])
        && data.keys().size() == 5
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && data.role in ['student', 'teacher', 'admin'];
    }

    // ---------------------------------------------------------
    // RULES
    // ---------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }

    match /contacts/{contactId} {
      allow create: if isValidId(contactId) && isValidContact(incoming());
      allow list, get: if isSignedIn(); // Basic staff access, could be refined
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'role']);
    }
  }
}
